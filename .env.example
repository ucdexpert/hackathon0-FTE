# AI Employee Vault - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# GMAIL API (Using credentials.json - already configured)
# =============================================================================
# Gmail credentials are loaded from credentials.json automatically
# No need to set these unless you want to override

# =============================================================================
# LINKEDIN (Session-based authentication - recommended)
# =============================================================================
# LinkedIn uses browser session storage instead of API credentials
# First run: python scripts/watchers/linkedin_watcher.py --authenticate
# Session is saved automatically

# Optional: LinkedIn credentials for auto-login (less secure)
# LINKEDIN_EMAIL=your.email@example.com
# LINKEDIN_PASSWORD=your_password

# LinkedIn Watcher Settings
LINKEDIN_CHECK_INTERVAL=300
LINKEDIN_KEYWORDS=hiring,opportunity,partnership,invoice,payment

# =============================================================================
# WHATSAPP (Session-based authentication)
# =============================================================================
# WhatsApp Web uses browser session storage
# First run will open browser for QR code scan

# WhatsApp Watcher Settings
WHATSAPP_CHECK_INTERVAL=30
WHATSAPP_KEYWORDS=urgent,asap,invoice,payment,help

# =============================================================================
# GENERAL SETTINGS
# =============================================================================
VAULT_PATH=.
LOG_LEVEL=INFO
DRY_RUN=false

# =============================================================================
# SCHEDULER SETTINGS
# =============================================================================
# Check interval for various operations
ORCHESTRATOR_INTERVAL=30
PLAN_GENERATOR_INTERVAL=300
