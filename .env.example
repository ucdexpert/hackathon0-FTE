# Instagram Business Account ID (Optional)
# Required for Instagram posting
# Get from Graph API: GET /me?fields=instagram_business_account
# Must connect Instagram Business account to Facebook Page
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id

# =============================================================================
# ODOO ERP CONFIGURATION
# Required for Odoo accounting integration
# =============================================================================

# Odoo Server Host
ODOO_HOST=localhost

# Odoo Server Port (default: 8069)
ODOO_PORT=8069

# Odoo Database Name
ODOO_DB=odoo

# Odoo Username/Email
ODOO_USERNAME=admin

# Odoo Password or API key
ODOO_PASSWORD=admin

# =============================================================================
# GMAIL API CONFIGURATION
# Required for Gmail Watcher and Email MCP
# =============================================================================

# Gmail API Credentials
# Get from: https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=your_client_id
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REDIRECT_URI=http://localhost:8080

# Gmail API Scopes (comma-separated)
# Default: gmail.readonly,gmail.send,gmail.compose
GMAIL_SCOPES=gmail.readonly,gmail.send,gmail.compose

# =============================================================================
# LINKEDIN SETTINGS
# Used by LinkedIn Watcher and Auto Poster
# =============================================================================

# LinkedIn Check Interval (seconds)
LINKEDIN_CHECK_INTERVAL=300

# LinkedIn Keywords to Monitor
LINKEDIN_KEYWORDS=hiring,opportunity,partnership,invoice,payment

# LinkedIn Session Path (auto-created)
# LINKEDIN_SESSION_PATH=.linkedin_session

# =============================================================================
# WHATSAPP SETTINGS
# Used by WhatsApp Watcher (Playwright-based)
# =============================================================================

# WhatsApp Check Interval (seconds)
WHATSAPP_CHECK_INTERVAL=30

# WhatsApp Keywords to Monitor
WHATSAPP_KEYWORDS=urgent,asap,invoice,payment,help

# WhatsApp Session Path (auto-created)
# WHATSAPP_SESSION_PATH=.whatsapp_session

# =============================================================================
# GENERAL SETTINGS
# =============================================================================

# Path to Obsidian Vault
VAULT_PATH=.

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Dry Run Mode (true/false)
# If true, no actual actions will be taken (safe for testing)
DRY_RUN=false

# =============================================================================
# SCHEDULER SETTINGS
# =============================================================================

# Orchestrator Check Interval (seconds)
ORCHESTRATOR_INTERVAL=30

# Plan Generator Check Interval (seconds)
PLAN_GENERATOR_INTERVAL=300

# CEO Briefing Day (0=Monday, 6=Sunday)
BRIEFING_DAY=0

# CEO Briefing Hour (6-9 AM recommended)
BRIEFING_HOUR=7

# =============================================================================
# MCP SERVER SETTINGS
# =============================================================================

# Email MCP Server Port
EMAIL_MCP_PORT=8809

# Odoo MCP Server Port
ODOO_MCP_PORT=8810

# Social Media MCP Server Port
SOCIAL_MCP_PORT=8811

# =============================================================================
# API KEYS (For Future Integrations)
# =============================================================================

# Twitter/X API (Optional - for future Twitter integration)
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=

# Slack API (Optional - for future Slack integration)
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=

# =============================================================================
# SECURITY NOTES
# =============================================================================
# 
# 1. NEVER commit .env to version control
# 2. Rotate tokens/passwords regularly
# 3. Use long-lived tokens for production
# 4. Keep API keys confidential
# 5. Use separate credentials for development and production
#
# =============================================================================
